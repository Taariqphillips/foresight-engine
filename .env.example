# ============================================================
# FORESIGHT ENGINE - ENVIRONMENT CONFIGURATION
# ============================================================

# ─────────────────────────────────────────────────────────────
# ANTHROPIC API (REQUIRED)
# ─────────────────────────────────────────────────────────────
# Get your API key from: https://console.anthropic.com
# Powers the synthesis layer that generates insights
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ─────────────────────────────────────────────────────────────
# EMAIL DELIVERY (REQUIRED)
# ─────────────────────────────────────────────────────────────
# Gmail SMTP configuration
# SMTP_PASS must be a Gmail App Password, not your regular password
# Generate at: Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_character_app_password
DELIVERY_EMAIL=your_email@gmail.com

# ─────────────────────────────────────────────────────────────
# SCHEDULING
# ─────────────────────────────────────────────────────────────
# Daily brief schedule in cron format
# Default: "15 4 * * *" (4:15 AM every day)
# Format: "minute hour * * *"
BRIEF_CRON=15 4 * * *

# Timezone for scheduled jobs
# Use IANA timezone names (e.g., America/New_York, America/Los_Angeles)
TIMEZONE=America/Chicago

# ─────────────────────────────────────────────────────────────
# ALERT THRESHOLD
# ─────────────────────────────────────────────────────────────
# Minimum relevance score (0-100) to trigger real-time email alerts
# Signals scoring above this threshold send immediate alerts
# Recommended: 85 (only the highest-priority signals)
ALERT_THRESHOLD=85

# ─────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────
# Port for Express server (feedback API and dashboard)
PORT=3000

# Node environment
NODE_ENV=development

# Feedback URL for email button links
# In development: http://localhost:3000
# In production: https://your-app-name.onrender.com
FEEDBACK_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# NEWSAPI (OPTIONAL)
# ─────────────────────────────────────────────────────────────
# Get a free API key from: https://newsapi.org
# Provides 100 requests/day on free tier
# Enhances web scanning beyond RSS feeds
# If not provided, the engine will still function with RSS feeds only
NEWSAPI_KEY=optional_your_key_here
